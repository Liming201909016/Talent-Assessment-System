{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Go: Build",
      "type": "shell",
      "command": "cd 'Go-based Refactored System'; go build -o bin/server.exe ./cmd/server",
      "group": "build",
      "problemMatcher": ["$go"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Go: Test All",
      "type": "shell",
      "command": "cd 'Go-based Refactored System'; go test ./... -v -count=1",
      "group": "test",
      "problemMatcher": ["$go"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Go: Test Coverage",
      "type": "shell",
      "command": "cd 'Go-based Refactored System'; go test ./... -coverprofile=coverage.out; go tool cover -html=coverage.out -o coverage.html",
      "group": "test",
      "problemMatcher": ["$go"],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Go: Lint",
